{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "ES2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./web/src/*"]
    }
  },
  "include": [
    "remotion/**/*.ts",
    "remotion/**/*.tsx",
    "src/compositions/**/*.ts",
    "src/compositions/**/*.tsx"
  ]
}
