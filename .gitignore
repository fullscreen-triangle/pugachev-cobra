# ---- Node / Next.js --------------------------------------------------
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ---- Python ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
develop-eggs/
downloads/
eggs/
.eggs/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
.venv/
venv/
ENV/
env/
.python-version
dist/
build/
sdist/
wheels/
parts/
var/
lib64/

# ---- Rust (future compiler) -----------------------------------------
target/
Cargo.lock
**/*.rs.bk

# ---- Build outputs ---------------------------------------------------
*.min.js
*.min.css

# ---- Logs ------------------------------------------------------------
logs/
*.log
log/

# ---- Databases -------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# ---- Environment variables -------------------------------------------
.env
.env.local
.env.*.local
.envrc

# ---- Compressed files ------------------------------------------------
*.zip
*.tar.gz
*.rar
*.7z

# ---- Temporary / cache -----------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.cache
.nyc_output/
coverage/
.coverage
htmlcov/
*.cover

# ---- IDE -------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ---- OS --------------------------------------------------------------
.DS_Store
__MACOSX/
Thumbs.db
Desktop.ini

# ---- Project-specific ------------------------------------------------
/effects