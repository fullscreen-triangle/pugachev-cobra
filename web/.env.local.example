# Copy this file to .env.local and fill in your token.
# Get a free HuggingFace token at https://huggingface.co/settings/tokens
# The token needs at least "read" scope for public models.
# For Diffusion-As-Shader and VideoFrom3D, the free Inference API tier
# has rate limits; upgrade to PRO for longer videos and lower latency.

HF_TOKEN=hf_your_token_here
